    {"name": "label_size", "type": "number", "required": false, "default": 3.5, "allowed": "[1, 20]", "description": "Label text size."},
    {"name": "label_box_padding", "type": "number", "required": false, "default": 0.35, "allowed": "[0, 5]", "description": "Visual padding used by label repulsion."},
    {"name": "show_legend", "type": "boolean", "required": false, "default": false, "allowed": [true, false], "description": "Show the existing categorical legend."},
    {"name": "legend_position", "type": "string", "required": false, "default": "right", "allowed": ["right", "left", "top", "bottom", "none"], "description": "Position of the existing categorical legend."},
    {"name": "base_size", "type": "number", "required": false, "default": 11, "allowed": "[6, 30]", "description": "Base typography size."},
    {"name": "coordinate_padding", "type": "number", "required": false, "default": 0.12, "allowed": "[0, 1]", "description": "Purely visual coordinate expansion that does not transform coordinates."},
    {"name": "title", "type": "string|null", "required": false, "default": null, "allowed": null, "description": "Optional descriptive title."}
  ],
  "visual_revision": {
    "parameter_policy": "declared-only", "max_rounds": 3,
    "issue_parameter_map": {
